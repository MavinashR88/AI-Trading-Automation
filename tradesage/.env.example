# Trading — Alpaca (paper + live, free at alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # switch to live URL when toggled

# LLM
ANTHROPIC_API_KEY=

# LLM Mode: "testing" (Haiku, ~$0.05-0.20/day) | "live" (Sonnet+Haiku, ~$0.30-0.80/day) | "free" (Ollama, $0/day)
LLM_MODE=testing
LLM_DAILY_BUDGET_USD=1.00

# Ollama (used when LLM_MODE=free or budget exhausted)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# News + Web Research — Tavily replaces NewsAPI + Benzinga entirely
TAVILY_API_KEY=       # tavily.com (free tier: 1000 searches/month)

# Knowledge Graph — Neo4j (free Community Edition via Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tradesage

# Trading mode: "paper" or "live"
TRADING_MODE=paper

# Portfolio
STARTING_CAPITAL=50000

# Optional: crypto exchange via CCXT (e.g. Binance, Coinbase)
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
